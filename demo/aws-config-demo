# =============================================================================
# Demo AWS SSO Config — showcases all extension features
# Place this at ~/.aws/config (or point the extension preference to this file)
# =============================================================================

# ---------------------------------------------------------------------------
# SSO Session (shared by all profiles)
# ---------------------------------------------------------------------------
[sso-session acme-sso]
sso_start_url = https://acme-corp.awsapps.com/start/
sso_region = us-east-1
sso_registration_scopes = sso:account:access

# ---------------------------------------------------------------------------
# 🔴 Production — stage auto-detected, multiple roles (Admin, ReadOnly, PowerUser)
# ---------------------------------------------------------------------------
[profile AdministratorAccess-acme-production]
sso_session = acme-sso
sso_account_id = 111122223333
sso_role_name = AdministratorAccess
region = us-east-1

[profile ReadOnlyAccess-acme-production]
sso_session = acme-sso
sso_account_id = 111122223333
sso_role_name = ReadOnlyAccess
region = us-east-1

[profile PowerUserAccess-acme-production]
sso_session = acme-sso
sso_account_id = 111122223333
sso_role_name = PowerUserAccess
region = us-east-1

